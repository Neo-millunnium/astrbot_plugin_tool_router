{
    "enable": {
        "description": "启用动态工具路由插件",
        "type": "bool",
        "default": true
    },
    "top_k": {
        "description": "每次保留的最多工具数量（越小越省 token）",
        "type": "int",
        "default": 10
    },
    "min_similarity": {
        "description": "最小语义相似度阈值 (0-1)，越高过滤越严格",
        "type": "float",
        "default": 0.3
    },
    "embedding_provider_id": {
        "description": "使用的 Embedding Provider ID（留空则自动选择第一个可用的）",
        "type": "string",
        "default": "",
        "hint": "例如: openai_embedding_main, ollama_embedding, siliconflow_embedding"
    },
    "embedding_model_name": {
        "description": "覆盖 Embedding Provider 的模型名称（留空则使用提供商默认模型）",
        "type": "string",
        "default": "",
        "hint": "例如: text-embedding-3-small, bge-large-zh-v1.5, BAAI/bge-m3"
    },
    "whitelist_tools": {
        "description": "白名单工具列表，这些工具不会被路由过滤，始终保留给 Agent 使用。可在此增删工具名称",
        "type": "list",
        "default": [
            "astrbot_execute_shell",
            "astrbot_execute_python",
            "astrbot_file_read_tool",
            "astrbot_file_write_tool",
            "astrbot_file_edit_tool",
            "astrbot_grep_tool",
            "send_message_to_user",
            "future_task_tool",
            "astrbot_web_search",
            "astrbot_fetch_webpage"
        ],
        "item_type": "string",
        "hint": "每行一个工具名称，例如：astrbot_execute_shell"
    }
}
